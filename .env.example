# Copy this file to .env (same directory as docker-compose.yml) and fill in.
# .env is gitignored — never commit it.
#
# How to get a client ID: see "Getting Google OAuth credentials" in README.md.
# Only the client ID is needed — NOT the client secret (we verify ID tokens,
# we never exchange authorization codes).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
